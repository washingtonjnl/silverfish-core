# Silverfish API configuration — copy to .env.local and adjust.
# Precedence: real env var > .env.local > .env > default. Secrets go in
# .env.local (gitignored). Defaults run out of the box; everything below is
# optional unless noted.

# --- Library -----------------------------------------------------------------
# standalone (default): the core owns the DB. calibre: read an existing Calibre
# metadata.db (must already exist).
SILVERFISH_LIBRARY_MODE=standalone

# Single folder the local defaults (book DB, system DB, storage) derive from.
SILVERFISH_LIBRARY_DIR=/path/to/library

# --- Databases (override the LIBRARY_DIR defaults; SQLite path or DB URL) -----
# Book library (standalone is SQLite-only for now).
# SILVERFISH_LIBRARY_DB=/data/library.db
# System store — always separate from the library. Postgres needs the 'postgres' extra.
# SILVERFISH_SYSTEM_DB=postgresql+psycopg://user:pass@host:5432/silverfish

# Per-node id (0-1023) for the book-id generator; keep distinct across nodes.
# SILVERFISH_MACHINE_ID=0

# --- Calibre binaries (for conversion + non-EPUB metadata) -------------------
# Autodetected when unset. EPUB works without them.
# SILVERFISH_CALIBRE_BIN_DIR=/Applications/calibre.app/Contents/MacOS

# --- API ---------------------------------------------------------------------
# Public URL the API is reached at — used for absolute links in emails. Required
# for export; without it the export endpoint returns a clear 503.
SILVERFISH_PUBLIC_BASE_URL=http://localhost:8000

# --- SMTP (send-to-ereader; required for export delivery) --------------------
# Empty host => sending unavailable (503). Read once at startup, never per-request.
# SILVERFISH_SMTP_HOST=smtp.gmail.com
# SILVERFISH_SMTP_PORT=587
# SILVERFISH_SMTP_USERNAME=you@gmail.com
# SILVERFISH_SMTP_PASSWORD=your-app-password
# SILVERFISH_SMTP_FROM=you@gmail.com
# SILVERFISH_SMTP_SECURITY=starttls   # none | starttls | ssl
# SILVERFISH_SMTP_MAX_ATTACHMENT_MB=25

# --- Storage: local (default) ------------------------------------------------
# Pick ONE storage block (local | s3 | gdrive) by leaving its SILVERFISH_STORAGE
# uncommented along with its settings; comment out the others.
SILVERFISH_STORAGE=local
# Files dir, independent of the DB. Defaults to LIBRARY_DIR.
# SILVERFISH_STORAGE_DIR=/mnt/book-files

# --- Export ------------------------------------------------------------------
# Link/zip TTL and the sweep that deletes expired zips. dir holds the zips.
# SILVERFISH_EXPORT_TTL_MINUTES=1440
# SILVERFISH_EXPORT_PURGE_INTERVAL_MINUTES=60
# SILVERFISH_EXPORT_DIR=/var/tmp/silverfish-exports

# --- Storage: S3 (needs the 's3' extra) --------------------------------------
# Bucket required; endpoint for S3-compatible (MinIO/R2). Omit keys to use the
# ambient credential chain (IAM role/profile). Keys are secrets.
# SILVERFISH_STORAGE=s3
# SILVERFISH_S3_BUCKET=my-library-bucket
# SILVERFISH_S3_REGION=us-east-1
# SILVERFISH_S3_ENDPOINT_URL=
# SILVERFISH_S3_PREFIX=books
# SILVERFISH_S3_ACCESS_KEY_ID=
# SILVERFISH_S3_SECRET_ACCESS_KEY=

# --- Storage: Google Drive (needs the 'gdrive' extra) ------------------------
# Get client id/secret from a Google Cloud project (Desktop app), then run
# `uv run python scripts/gdrive_authorize.py` to print the refresh token and
# folder id. All are secrets.
# SILVERFISH_STORAGE=gdrive
# SILVERFISH_GDRIVE_CLIENT_ID=
# SILVERFISH_GDRIVE_CLIENT_SECRET=
# SILVERFISH_GDRIVE_REFRESH_TOKEN=
# SILVERFISH_GDRIVE_FOLDER_ID=
