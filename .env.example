# Silverfish API configuration — copy to .env.local and adjust.
#
# Precedence (highest first): real env var > .env.local > .env > default.
# .env.local is gitignored and is where secrets belong.

# --- Library mode -----------------------------------------------------------
# How the book library database is owned:
#   standalone (default) — the core creates and owns the database (our schema;
#                          SQLite locally or Postgres). Open it in Calibre
#                          desktop via an on-demand export, not live sync.
#   calibre              — the core reads an EXISTING Calibre metadata.db (API
#                          over your local Calibre). The file must already exist;
#                          the core never creates it.
SILVERFISH_LIBRARY_MODE=standalone

# Convenience: a single folder from which the local defaults below are derived
# (book DB, system DB and storage). If unset, a local "silverfish-library"
# directory is used so the API runs out of the box.
SILVERFISH_LIBRARY_DIR=/path/to/library

# --- Databases (independent; each a SQLite path or a SQLAlchemy URL) ---------
# Explicit connection strings override the LIBRARY_DIR-derived defaults. A bare
# path is treated as a SQLite file; a scheme:// value is used as-is.
#
# Book library. Default derives from LIBRARY_DIR: library.db (standalone) or
# metadata.db (calibre). Postgres for the *library* is not wired yet (standalone
# is SQLite-only for now); the system store below may use Postgres.
# SILVERFISH_LIBRARY_DB=/data/library.db
#
# System store (Silverfish's own config). ALWAYS a separate database from the
# library. Default derives from LIBRARY_DIR: system.db.
# SILVERFISH_SYSTEM_DB=postgresql+psycopg://user:pass@host:5432/silverfish
#   (Postgres for the system store requires the optional 'postgres' extra.)

# Per-node id for the time-ordered book-id generator (standalone). Give each
# node a distinct value (0-1023) so ids never collide; 0 is fine for one process.
# SILVERFISH_MACHINE_ID=0

# Directory holding the Calibre binaries (ebook-convert, ebook-meta). Optional:
# when unset they are autodetected from the OS default install location. Needed
# for format conversion and for metadata/cover extraction of non-EPUB formats.
# SILVERFISH_CALIBRE_BIN_DIR=/Applications/calibre.app/Contents/MacOS

# --- SMTP (send books to a Kindle/e-reader by email) ------------------------
# When SILVERFISH_SMTP_HOST is empty, sending is unavailable (the send endpoint
# returns 503). These credentials are read once at startup and never travel in
# a send request. Keep real values in .env.local.
# SILVERFISH_SMTP_HOST=smtp.gmail.com
# SILVERFISH_SMTP_PORT=587
# SILVERFISH_SMTP_USERNAME=you@gmail.com
# SILVERFISH_SMTP_PASSWORD=your-app-password
# SILVERFISH_SMTP_FROM=you@gmail.com
# SILVERFISH_SMTP_SECURITY=starttls   # none | starttls | ssl
# SILVERFISH_SMTP_MAX_ATTACHMENT_MB=25

# Where book files are stored. One of: local | s3 | gdrive.
# Default is "local". 's3' is implemented (needs the 's3' extra: boto3); gdrive
# is planned and raises a clear "not implemented" error if selected.
SILVERFISH_STORAGE=local

# Directory for the book files, configured independently of the database (in a
# SaaS the files may live on Drive/S3, unrelated to where metadata sits). When
# unset it defaults to SILVERFISH_LIBRARY_DIR.
# SILVERFISH_STORAGE_DIR=/mnt/book-files

# Public base URL the API is reachable at (scheme + host + optional port). Used
# to build absolute, clickable links in emails (e.g. the export download link).
# Set it to where clients actually reach the API. Without it, emailed links are
# relative and the export endpoint refuses with a clear error.
#   dev:  http://localhost:8000
#   prod: https://library.example.com
SILVERFISH_PUBLIC_BASE_URL=http://localhost:8000

# --- Calibre export ---------------------------------------------------------
# POST /export/calibre snapshots the library to a Calibre-format zip, runs it as
# an async job, and emails a time-limited download link (the zip is never
# attached — a library can exceed any mail server's limit). Needs SMTP
# configured, the calibredb binary present, and SILVERFISH_PUBLIC_BASE_URL set.
# The download link/zip expires after this many minutes (default 1440 = 24h),
# then it is deleted. A background sweep removes expired zips (local and remote)
# every EXPORT_PURGE_INTERVAL_MINUTES (default 60). export_dir holds the zips
# (defaults to <library_dir>/exports).
# SILVERFISH_EXPORT_TTL_MINUTES=1440
# SILVERFISH_EXPORT_PURGE_INTERVAL_MINUTES=60
# SILVERFISH_EXPORT_DIR=/var/tmp/silverfish-exports

# --- S3 (or S3-compatible) storage ------------------------------------------
# Used when SILVERFISH_STORAGE=s3. Needs the 's3' extra (boto3). Bucket is
# required; region/endpoint are optional (endpoint for MinIO/Cloudflare R2/etc).
# prefix scopes keys within the bucket. Keys are secrets -> keep in .env.local.
# When the access key is omitted, boto3 uses the ambient credential chain (IAM
# role, profile). With S3, an export's download link is a presigned URL served
# directly by S3 (the download bypasses the API server); on local storage the
# API serves the zip itself.
# SILVERFISH_S3_BUCKET=my-library-bucket
# SILVERFISH_S3_REGION=us-east-1
# SILVERFISH_S3_ENDPOINT_URL=
# SILVERFISH_S3_PREFIX=books
# SILVERFISH_S3_ACCESS_KEY_ID=
# SILVERFISH_S3_SECRET_ACCESS_KEY=

# --- Google Drive storage ---------------------------------------------------
# Used when SILVERFISH_STORAGE=gdrive. Needs the 'gdrive' extra
# (google-api-python-client + google-auth). Get the OAuth client id/secret from
# a Google Cloud project (Desktop app), then run the one-off helper once:
#   SILVERFISH_GDRIVE_CLIENT_ID=... SILVERFISH_GDRIVE_CLIENT_SECRET=... \
#     uv run python scripts/gdrive_authorize.py
# It opens a consent flow (least-privilege drive.file scope), creates the
# library folder, and PRINTS both GDRIVE_REFRESH_TOKEN and GDRIVE_FOLDER_ID —
# paste them below. (The app only touches folders it created; deciding which
# folder to use is the consumer's job — a SaaS resolves it per tenant.) All are
# secrets -> keep in .env.local. With Drive, an export's download link is a
# share link Google serves.
# SILVERFISH_GDRIVE_CLIENT_ID=
# SILVERFISH_GDRIVE_CLIENT_SECRET=
# SILVERFISH_GDRIVE_REFRESH_TOKEN=
# SILVERFISH_GDRIVE_FOLDER_ID=
