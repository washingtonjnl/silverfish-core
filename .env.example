# Silverfish API configuration — copy to .env.local and adjust.
#
# Precedence (highest first): real env var > .env.local > .env > default.
# .env.local is gitignored and is where secrets belong.

# Path to a Calibre library folder (the directory containing metadata.db and the
# book files). If unset, a local "silverfish-library" directory is used so the
# API runs out of the box.
SILVERFISH_LIBRARY_DIR=/path/to/Calibre Library

# Where book files are stored. One of: local | gdrive | s3.
# Default is "local" (files under SILVERFISH_LIBRARY_DIR). gdrive and s3 are
# planned; selecting them today raises a clear "not implemented" error.
SILVERFISH_STORAGE=local

# --- Cloud storage credentials (not implemented yet) ------------------------
# These are placeholders documenting the extension point. When the Drive/S3
# adapters land, they will be read from here (keep real values in .env.local).
#
# Google Drive:
# SILVERFISH_GDRIVE_CLIENT_ID=
# SILVERFISH_GDRIVE_CLIENT_SECRET=
# SILVERFISH_GDRIVE_REFRESH_TOKEN=
# SILVERFISH_GDRIVE_FOLDER_ID=
#
# S3 (or S3-compatible):
# SILVERFISH_S3_BUCKET=
# SILVERFISH_S3_REGION=
# SILVERFISH_S3_ACCESS_KEY_ID=
# SILVERFISH_S3_SECRET_ACCESS_KEY=
# SILVERFISH_S3_ENDPOINT_URL=
